module Pseudonymous
{


/************************RECIPES************************/
    craftRecipe SaltMeat
 	{
        timedAction = SliceMeat_Surface,
 		Time = 150,
 		OnCreate = Recipe.OnCreate.CutChicken,
 		Tags = AnySurfaceCraft;Cooking,
		category = Cooking,
 		xpAward = Cooking:10,
 		inputs
 		{
 			item 1 tags[SharpKnife;MeatCleaver] mode:keep flags[IsNotDull;SharpnessCheck],
			item 2 [Base.Salt],
 			item 1 [Base.Rabbitmeat] mappers[meatType] flags[InheritFoodAge],
 		}
 		outputs
 		{
 			item 1 mapper:meatType,
        }
        itemMapper meatType
        {
            Pseudonymous.SaltedRabbit = Base.Rabbitmeat,
        }
 	}
    
	craftRecipe MakeSaltedFillet
	{
        timedAction = SliceMeat_Surface,
		Time = 150,
		OnCreate = Recipe.OnCreate.CutFillet,
		OnTest = Recipe.OnTest.CutFillet,
		Tags = AnySurfaceCraft;Cooking,
		category = Cooking,
		xpAward = Cooking:5,
		inputs
		{
			item 1 tags[SharpKnife;MeatCleaver] mode:keep flags[MayDegradeLight;IsNotDull;SharpnessCheck],
			item 2 [Base.Salt],
			item 1 [Base.FishFillet] flags[InheritFoodAge],
		}
		outputs
		{
			item 2 Pseudonymous.SaltedFishFillet,
		}
	}
    
    craftRecipe GetSalt
    {
        timedAction = OpenTinCan,
        time = 200,
        tags = InHandCraft;CanBeDoneInDark,
		category = Cooking,
        inputs
        {
            item 1 [Pseudonymous.SaltPot;Pseudonymous.SaltKettle] mappers[saltwaterContainers],
        }
        outputs
        {
            item 2 Base.Salt,
            item 1 mapper:saltwaterContainers,
        }
        itemMapper saltwaterContainers
        {
            Base.Pot = Base.SaltPot,
            Base.Kettle = Base.SaltKettle,
        }
    }
    


}
